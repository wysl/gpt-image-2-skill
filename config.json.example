{
  "endpoints": [
    {
      "name": "your-provider-1",
      "url": "https://your-api-endpoint.example/v1",
      "model": "gpt-image-2",
      "key": "YOUR_API_KEY_HERE",
      "priority": 1,
      "timeout": 500,
      "enabled": true
    },
    {
      "name": "your-provider-2",
      "url": "https://another-api-endpoint.example/v1",
      "model": "gpt-image-2",
      "key": "YOUR_API_KEY_HERE",
      "priority": 2,
      "timeout": 500,
      "enabled": false
    }
  ],
  "default_model": "gpt-image-2",
  "retry_count": 1,
  "output_dir": "~/.hermes/output/gpt-image-2"
}
